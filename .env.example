# Database connection string for PostgreSQL
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend port
PORT=8000

# Frontend API URL pointing to the backend
VITE_API_URL=http://localhost:8000

# PostgreSQL environment variables
POSTGRES_USER=appuser  # Username for PostgreSQL
POSTGRES_PASSWORD=<password>  # Password for PostgreSQL
POSTGRES_DB=appdb  # Database name for PostgreSQL

# OpenAI API key for embeddings and generation
OPENAI_API_KEY=<your_openai_api_key>  # API key for OpenAI services

# Optional: Other LLM API keys (if applicable)
ANTHROPIC_API_KEY=<your_anthropic_api_key>  # API key for Anthropic services
GOOGLE_GEMINI_API_KEY=<your_google_gemini_api_key>  # API key for Google Gemini services